# ============================================================
# witness — example environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# Container / registry
ECR_REGISTRY=your-registry-name
TAG=latest

# Runtime environment: development | staging | production
ENVIRONMENT=development

# Logging
LOG_LEVEL=info

# ---- Database --------------------------------------------------
# SQLite (default, no extra config needed)
DATABASE_URL=sqlite:////app/data/fitness.db

# ---- Security --------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-string
CSRF_SECRET=replace-with-random-secret

# ---- Admin user ------------------------------------------------
# Created automatically on first startup if it doesn't exist.
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me-use-a-strong-password

# ---- Server ----------------------------------------------------
WEB_WORKERS=4
HTTP_PORT=8000
HTTPS_PORT=8443

# ---- Storage (optional — defaults to local filesystem) ---------
# STORAGE_BACKEND=azure_blob
# AZURE_STORAGE_ACCOUNT=your-storage-account
# AZURE_CONTAINER_NAME=certs
# AZURE_SAS_TOKEN=your-sas-token

# ---- External APIs (all optional) -----------------------------
# NIST_API_KEY=your-nist-nvd-api-key
# NASA_API_KEY=DEMO_KEY
# OPENWEATHERMAP_API_KEY=your-owm-key

# ---- Email (Resend) -------------------------------------------
# EMAIL_ENABLED=true
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM_NAME=Your Name
# EMAIL_FROM_ADDR=noreply@example.com
# EMAIL_TO_ADDR=inbox@example.com

# ---- Azure AI (optional RAG features) -------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_KEY=your-search-key
# ENABLE_RAG=false

# ---- Observability (optional) ---------------------------------
# ENABLE_TRACING=false
# OTLP_ENDPOINT=http://otel-collector:4317
# OTLP_HEADERS=Authorization=Bearer your-token

# ---- Grafana dashboard (optional) -----------------------------
# GRAFANA_PUBLIC_DASHBOARD_URL=https://grafana.example.com/d/public/...
